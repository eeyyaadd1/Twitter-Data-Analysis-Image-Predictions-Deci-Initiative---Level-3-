      "Name: dog_stage, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "# Check unique values in the new dog_stage column\n",
    "print(twitter_archive_clean['dog_stage'].value_counts(dropna=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Issue #2: Merge All DataFrames into master_df"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Define: After cleaning, we need to merge twitter_archive_clean, image_predictions_clean, and tweet_json_clean into one single DataFrame based on tweet_id."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Code"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 94,
   "metadata": {},
   "outputs": [],
   "source": [
    "# First merge twitter_archive_clean with image_predictions_clean\n",
    "df_merged = pd.merge(twitter_archive_clean, image_predictions_clean, on='tweet_id', how='inner')\n",
    "\n",
    "# Then merge the result with tweet_json_clean\n",
    "master_df = pd.merge(df_merged, tweet_json_clean, on='tweet_id', how='inner')"
   ]
