  {
   "cell_type": "code",
   "execution_count": 71,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Tweet JSON Shape: (2354, 3)\n",
      "             tweet_id  retweet_count  favorite_count\n",
      "0  892420643555336193           8853           39467\n",
      "1  892177421306343426           6514           33819\n",
      "2  891815181378084864           4328           25461\n",
      "3  891689557279858688           8964           42908\n",
      "4  891327558926688256           9774           41048\n"
     ]
    }
   ],
   "source": [
    "# Read tweet-json.txt\n",
    "import pandas as pd\n",
    "import json\n",
    "\n",
    "try:\n",
    "    tweet_data = []\n",
    "    with open('tweet-json.txt', 'r', encoding='utf-8') as file:\n",
    "        for line in file:\n",
    "            try:\n",
    "                tweet = json.loads(line.strip())\n",
    "                tweet_data.append({\n",
    "                    'tweet_id': tweet['id'],\n",
    "                    'retweet_count': tweet['retweet_count'],\n",
    "                    'favorite_count': tweet['favorite_count']\n",
    "                })\n",
    "            except json.JSONDecodeError as e:\n",
    "                print(f\"Error parsing line: {line[:50]}... Error: {e}\")\n",
    "    tweet_json_df = pd.DataFrame(tweet_data, columns=['tweet_id', 'retweet_count', 'favorite_count'])\n",
    "    tweet_json_df['tweet_id'] = tweet_json_df['tweet_id'].astype(str)  # Convert to string\n",
    "    print(\"Tweet JSON Shape:\", tweet_json_df.shape)\n",
    "    print(tweet_json_df.head())\n",
    "except FileNotFoundError:\n",
    "    print(\"Error: tweet-json.txt not found.\")"
   ]
  },
