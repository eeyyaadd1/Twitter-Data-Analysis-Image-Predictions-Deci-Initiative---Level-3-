   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "master_df = pd.read_csv('twitter_archive_master.csv')\n",
    "\n",
    "# Dog Stage Distribution\n",
    "plt.figure(figsize=(10, 6))\n",
    "master_df['dog_stage'].value_counts(dropna=False).plot(kind='bar', color='skyblue')\n",
    "plt.title('Distribution of Dog Stages')\n",
    "plt.xlabel('Dog Stage')\n",
    "plt.ylabel('Count')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.savefig('dog_stage_distribution.png')\n",
    "plt.show()\n",
    "\n",
    "# Average Ratings by Dog Stage\n",
    "plt.figure(figsize=(10, 6))\n",
    "master_df.groupby('dog_stage')['rating_numerator'].mean().sort_values(ascending=False).plot(kind='bar', color='lightgreen')\n",
    "plt.title('Average Rating by Dog Stage')\n",
    "plt.xlabel('Dog Stage')\n",
    "plt.ylabel('Average Rating Numerator')\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.savefig('avg_rating_by_dog_stage.png')\n",
    "plt.show()\n",
    "\n",
    "# Retweets vs Favorites\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.regplot(x='retweet_count', y='favorite_count', data=master_df, fit_reg=False, scatter_kws={'alpha': 0.5})\n",
    "plt.title('Retweets vs Favorites')\n",
    "plt.xlabel('Retweet Count')\n",
    "plt.ylabel('Favorite Count')\n",
    "plt.tight_layout()\n",
    "plt.savefig('retweets_vs_favorites.png')\n",
    "plt.show()"
   ]
  }
