   "metadata": {},
   "source": [
    "#### Define: Dog stages are currently spread across four separate columns (doggo, floofer, pupper, puppo). For proper structure and easier analysis, these should be combined into a single column called dog_stage"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Code"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 92,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Replace 'None' strings with empty string to make combining easier\n",
    "stage_columns = ['doggo', 'floofer', 'pupper', 'puppo']\n",
    "for col in stage_columns:\n",
    "    twitter_archive_clean[col] = twitter_archive_clean[col].replace('None', '')\n",
    "\n",
    "# Combine all into one string and strip extra spaces\n",
    "twitter_archive_clean['dog_stage'] = twitter_archive_clean[stage_columns].agg(' '.join, axis=1).str.strip()\n",
    "\n",
    "# Replace multiple stages (like \"doggo puppo\") with NaN or a decision if needed\n",
    "twitter_archive_clean['dog_stage'] = twitter_archive_clean['dog_stage'].replace('', np.nan)\n",
    "\n",
    "# Drop the old stage columns\n",
    "twitter_archive_clean.drop(columns=stage_columns, inplace=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Test"
   ]
  },
